# Скопируйте в .env.production на сервере. Файл .env.production не коммитится и не попадает в Docker build context.

CLIENT_PORT=3000
SERVER_PORT=3001

DB_NAME=dino
DB_USER=dino
DB_PASSWORD=change-me

# На первом запуске без TLS можно использовать http://<ip-или-домен>.
# После выпуска сертификата смените на https://<домен> и пересоберите client.
EXTERNAL_SERVER_URL=http://example.com

# Внутренний адрес API для SSR-контейнера client внутри сети docker compose.
INTERNAL_SERVER_URL=http://server:3001
