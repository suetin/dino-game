# Скопируйте в .env.production на сервере. Файл .env.production не коммитится и не попадает в Docker build context.

CLIENT_PORT=3000
SERVER_PORT=3001

DB_NAME=dino
DB_USER=dino
DB_PASSWORD=change-me

# На первом запуске без TLS можно использовать http://<ip-или-домен>.
# После выпуска сертификата смените на https://<домен> и пересоберите client.
EXTERNAL_SERVER_URL=http://example.com
AUTH_CORS_ORIGIN_ALLOWLIST=http://example.com,https://example.com

# Внутренний адрес API для SSR-контейнера client внутри сети docker compose.
INTERNAL_SERVER_URL=http://server:3001

# Yandex OAuth (server-side code exchange)
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
# Список разрешенных redirect_uri через запятую (строгое совпадение после нормализации URL)
YANDEX_OAUTH_REDIRECT_URI_ALLOWLIST=https://example.com
OAUTH_HTTP_TIMEOUT_MS=5000
OAUTH_STATE_TTL_SEC=300
# Cookie Secure policy: auto|true|false
# Для первичного HTTP-развертывания оставьте auto/false, для HTTPS рекомендуется true.
COOKIE_SECURE=auto
