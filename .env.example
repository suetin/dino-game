# Скопируйте в .env в корне репозитория (файл .env в git не коммитится).
# Для docker compose можно не создавать .env — подставятся значения по умолчанию ниже.

CLIENT_PORT=3000
SERVER_PORT=3001
POSTGRES_PORT=5432

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Локальный backend без Docker: хост localhost.
POSTGRES_HOST=localhost

# Если задан непустой DATABASE_URL, Sequelize использует только его (POSTGRES_* для подключения игнорируются).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# URL API для браузера и клиентского JS (никогда не используйте имя сервиса Docker «server»).
EXTERNAL_SERVER_URL=http://localhost:3001

# Только SSR Node внутри контейнера client при сборке/рантайме в Docker-сети.
INTERNAL_SERVER_URL=http://localhost:3001
