# Скопируйте в .env в корне репозитория (файл .env в git не коммитится).
# Для docker compose можно не создавать .env — подставятся значения по умолчанию ниже.

CLIENT_PORT=3000
SERVER_PORT=3001
POSTGRES_PORT=5432

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Локальный backend без Docker: хост localhost.
POSTGRES_HOST=localhost

# Если задан непустой DATABASE_URL, Sequelize использует только его (POSTGRES_* для подключения игнорируются).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# URL API для браузера и клиентского JS (никогда не используйте имя сервиса Docker «server»).
EXTERNAL_SERVER_URL=http://localhost:3001
AUTH_CORS_ORIGIN_ALLOWLIST=http://localhost:3000

# Только SSR Node внутри контейнера client в Docker-сети (хост сервиса compose — server).
INTERNAL_SERVER_URL=http://server:3001

# Yandex OAuth (server-side code exchange)
# Создайте приложение в Yandex OAuth и укажите redirect URI, например http://localhost:3000
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
# Список разрешенных redirect_uri через запятую (строгое совпадение после нормализации URL)
YANDEX_OAUTH_REDIRECT_URI_ALLOWLIST=http://localhost:3000
OAUTH_HTTP_TIMEOUT_MS=5000
OAUTH_STATE_TTL_SEC=300
# Cookie Secure policy: auto|true|false
# auto (default): Secure only for HTTPS requests.
COOKIE_SECURE=auto
